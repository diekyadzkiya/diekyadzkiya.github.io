@inproceedings{2f70bade6c13450c9ff7950945ccac32,
title = "Ship heading control of warship using disturbance compensating model predictive control method",
abstract = "Warship is a military transportation designed for the Indonesian navy as one of the national defenses and safeguarding the security from enemy attacks. When carrying out its mission, the ship needs a heading control so that the ship stays robust against some disturbance such as sea wave and moves in accordance with the intended purpose. So in this paper, we will be design a ship heading control by using Disturbance Compensating Model Predictive Control (DC-MPC) method where mathematical model of the ship has 4 degree of freedom (surge, sway, yaw, roll) with sea water surface waves acting as the disturbance. In our experiments, we use two values for prediction horizon, i.e. 6 and 7. According to our simulation, the best performance is achieved in the case of prediction horizon equals 7, which corresponds to RMSE 0.02.",
keywords = "DC-MPC, Ship Heading Control, Warship, Wave Disturbance",
author = "Subchan and Aulia, \{Giska Ayu\} and Tahiyatul Asfihani and Dieky Adzkiya",
