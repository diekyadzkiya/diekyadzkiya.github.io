@article{dc8b928bd1b84a6db3b84ad74b95aea2,
title = "Business process improvement of production systems using coloured petri nets",
abstract = "The quality of information systems affects the company's business performance. Therefore, it is necessary to analyze business processes to determine any discrepancies between the planned business processes and the actual ones. Based on the results of this analysis, the business process can be improved. The fundamental factor of manufacturing companies is production process. In reality, there are many discrepancies between the actual business processes with the pre-planned, so that there should be analyzed. The analysis can be performed by modeling the business process using Coloured Petri Nets (CPN). In this study, the objectives are to determine the level of conformance checking of business processes, reachability graph and the bottleneck analysis. The results of the analysis are used to construct a recommended model. Based on the analysis of the case study, e.g. a steel industry in Indonesia, the recommended model has a better value than initial model.",
keywords = "Business process modeling, Coloured petri nets, Improvement of business process model",
author = "Imam Mukhlash and Rumana, \{Widya Nilam\} and Dieky Adzkiya and Riyanarto Sarno",
note = "Publisher Copyright: {\textcopyright} 2018 Institute of Advanced Engineering and Science. All rights reserved.",
