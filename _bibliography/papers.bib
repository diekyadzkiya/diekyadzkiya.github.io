editor = "Adem Kilicman and Marjono and Wibowo, \{Ratno Bagus Edy\} and Imron, \{Moch. Aruman\}",
booktitle = "International Conference and Workshop on Mathematical Analysis and its Applications, ICWOMAA 2017",
}

