booktitle = "Formal Modeling and Analysis of Timed Systems - 17th International Conference, FORMATS 2019, Proceedings",
address = "Germany",
}

@inproceedings{140fe5004dfd4e9ebcee5a73e6fde90d,
title = "Centralized and decentralized H-\{\textbackslash{}infty\} controller design for storey building systems using matrix inequality approach",
abstract = "Modern control methods have found their way into decentralized design of interconnected systems. Before we find decentralized controller, we first find the centralized controller. Centralized controller will be computed using Linear Matrix Inequality (LMI) approach and decentralized controller will be computed using Bilinear Matrix Inequality (BMI). The BMI will be solved using double LMI via homotopy method which can then be solved efficiently. Numerical example of centralized and decentralized controller of storey building system will be presented. The simulation results on centralized controller show that systems with centralized H-\{\textbackslash{}infty\} controls have better performance than systems without control, and simulation results on decentralized controller show that \textbackslash{}Vert T-\{zw\}(s)\textbackslash{}Vert-\{\textbackslash{}infty\} < \textbackslash{}gamma.",
keywords = "Bilinear Matrix Inequality, Centralized controller, Decentralized controller, Linear Matrix Inequality, Storey building systems",
